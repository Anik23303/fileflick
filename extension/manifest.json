{
  "manifest_version": 3,
  "name": "FileFlick Converter",
  "version": "1.0.0",
  "description": "Right-click any image to convert instantly. 100% free and private.",
  "permissions": ["contextMenus", "activeTab", "storage", "downloads"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
